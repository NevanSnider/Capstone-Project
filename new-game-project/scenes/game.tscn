[sub_resource type="GDScript" id="GDScript_rysoc"]
script/source = "extends SubViewport

func _ready():
	var main_world_2d = get_tree().root.world_2d
	var minimap_viewport = get_node(\"MinimapContainer/MinimapViewport\")
	
	if minimap_viewport:
		minimap_viewport.world_2d = main_world_2d
"

